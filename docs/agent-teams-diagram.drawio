<mxfile>
  <diagram name="Agent Teams" id="agent-teams-diagram">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Background container -->
        <mxCell id="bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0EDF5;strokeColor=#D0C8E0;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="820" height="600" as="geometry"/>
        </mxCell>

        <!-- Main Agent (Team Lead) -->
        <mxCell id="main" value="Main Agent (Team Lead)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B2FBE;fontColor=#FFFFFF;strokeColor=#5A1F8E;fontSize=16;fontStyle=1;arcSize=20;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="170" y="60" width="560" height="60" as="geometry"/>
        </mxCell>

        <!-- Spawn Team label -->
        <mxCell id="spawnLabel" value="Spawn Team &amp;&#xa;Assign Tasks" style="text;html=1;fontSize=12;fontColor=#2D2D2D;align=center;verticalAlign=middle;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="385" y="135" width="130" height="40" as="geometry"/>
        </mxCell>

        <!-- Arrow from Main Agent to Shared Task List -->
        <mxCell id="spawnArrow" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2D2D2D;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="main" target="taskList">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Shared Task List -->
        <mxCell id="taskList" value="Shared Task List" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8DEFA;fontColor=#2D2D2D;strokeColor=#7B2FBE;fontSize=16;fontStyle=1;arcSize=15;dashed=1;dashPattern=8 6;strokeWidth=2;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="170" y="195" width="560" height="60" as="geometry"/>
        </mxCell>

        <!-- Communicate & Claim Tasks labels -->
        <mxCell id="claim1" value="Communicate&#xa;&amp; Claim Tasks" style="text;html=1;fontSize=11;fontColor=#2D2D2D;align=center;verticalAlign=middle;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="115" y="275" width="110" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="claim2" value="Communicate&#xa;&amp; Claim Tasks" style="text;html=1;fontSize=11;fontColor=#2D2D2D;align=center;verticalAlign=middle;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="395" y="275" width="110" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="claim3" value="Communicate&#xa;&amp; Claim Tasks" style="text;html=1;fontSize=11;fontColor=#2D2D2D;align=center;verticalAlign=middle;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="665" y="275" width="110" height="35" as="geometry"/>
        </mxCell>

        <!-- Arrows from Task List to Teammates -->
        <mxCell id="claimArrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2D2D2D;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="taskList" target="tm1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="claimArrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2D2D2D;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="taskList" target="tm2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="claimArrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2D2D2D;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="taskList" target="tm3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Teammates -->
        <mxCell id="tm1" value="Teammate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8D5F5;fontColor=#2D2D2D;strokeColor=#7B2FBE;fontSize=14;fontStyle=1;arcSize=15;strokeWidth=2;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="340" width="140" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="tm2" value="Teammate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8D5F5;fontColor=#2D2D2D;strokeColor=#7B2FBE;fontSize=14;fontStyle=1;arcSize=15;strokeWidth=2;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="340" width="140" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="tm3" value="Teammate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8D5F5;fontColor=#2D2D2D;strokeColor=#7B2FBE;fontSize=14;fontStyle=1;arcSize=15;strokeWidth=2;fontFamily=Helvetica;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="340" width="140" height="65" as="geometry"/>
        </mxCell>

        <!-- Communicate arrows between teammates -->
        <mxCell id="comm12" style="html=1;strokeColor=#888888;strokeWidth=2;endArrow=block;endFill=1;startArrow=block;startFill=1;" edge="1" parent="1" source="tm1" target="tm2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="commLabel12" value="Communicate" style="text;html=1;fontSize=11;fontColor=#888888;align=center;verticalAlign=middle;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="255" y="350" width="110" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="comm23" style="html=1;strokeColor=#888888;strokeWidth=2;endArrow=block;endFill=1;startArrow=block;startFill=1;" edge="1" parent="1" source="tm2" target="tm3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="commLabel23" value="Communicate" style="text;html=1;fontSize=11;fontColor=#888888;align=center;verticalAlign=middle;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="535" y="350" width="110" height="20" as="geometry"/>
        </mxCell>

        <!-- Work loops -->
        <mxCell id="workLoop1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#888888;strokeWidth=2;endArrow=block;endFill=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;curved=1;" edge="1" parent="1" source="tm1" target="tm1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="60" y="405"/>
              <mxPoint x="60" y="480"/>
              <mxPoint x="60" y="373"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="workLabel1" value="Work" style="text;html=1;fontSize=12;fontColor=#2D2D2D;align=center;verticalAlign=middle;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="50" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="workLoop2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#888888;strokeWidth=2;endArrow=block;endFill=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;curved=1;" edge="1" parent="1" source="tm2" target="tm2">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="340" y="405"/>
              <mxPoint x="340" y="480"/>
              <mxPoint x="340" y="373"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="workLabel2" value="Work" style="text;html=1;fontSize=12;fontColor=#2D2D2D;align=center;verticalAlign=middle;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="320" y="430" width="50" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="workLoop3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#888888;strokeWidth=2;endArrow=block;endFill=1;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;curved=1;" edge="1" parent="1" source="tm3" target="tm3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="840" y="405"/>
              <mxPoint x="840" y="480"/>
              <mxPoint x="840" y="373"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="workLabel3" value="Work" style="text;html=1;fontSize=12;fontColor=#2D2D2D;align=center;verticalAlign=middle;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="815" y="430" width="50" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>