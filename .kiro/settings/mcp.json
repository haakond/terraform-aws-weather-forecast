{
  "mcpServers": {
    "power-aws-agentcore-agentcore-mcp-server": {
      "disabled": true
    },
    "power-aws-agentcore-strands-mcp-server": {
      "disabled": true
    },
    "power-cloud-architect-context7": {
      "disabled": true
    },
    "power-cloud-architect-awsknowledge": {
      "disabled": true
    },
    "power-aws-finops-cost-estimator-aws-docs": {
      "disabled": true
    },
    "power-aws-finops-cost-estimator-aws-pricing": {
      "disabled": true
    },
    "power-strands-strands-agents": {
      "disabled": true
    },
    "awslabs-knowledge-mcp-server": {
      "url": "https://knowledge-mcp.global.api.aws",
      "type": "http",
      "disabled": false,
      "autoApprove": [
        "aws___search_documentation",
        "aws___read_documentation"
      ]
    },
    "github-mcp-server": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "disabled": false,
      "autoApprove": [],
      "disabledTools": [
        "assign_copilot_to_issue",
        "create_repository",
        "fork_repository",
        "merge_pull_request",
        "request_copilot_review",
        "search_users"
      ]
    },
    "awslabs-terraform": {
      "command": "uvx",
      "args": [
        "awslabs.terraform-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "autoApprove": [
        "SearchAwsProviderDocs",
        "SearchAwsccProviderDocs",
        "SearchUserProvidedModule",
        "SearchSpecificAwsIaModules",
        "RunCheckovScan",
        "ExecuteTerraformCommand"
      ]
    },
    "awslabs-api": {
      "command": "uvx",
      "args": [
        "awslabs.aws-api-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "autoApprove": [
        "suggest_aws_commands",
        "call_aws"
      ]
    }
  }
}